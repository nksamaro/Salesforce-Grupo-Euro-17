    <formulas>
        <name>ISNEW</name>
        <dataType>Boolean</dataType>
        <expression>ISNEW()</expression>
    </formulas>
    <formulas>
        <name>LTVItau</name>
        <dataType>Currency</dataType>
        <expression>{!$Record.ValorBem__c} - ({!$Record.ValorBem__c}*0.1)</expression>
        <scale>2</scale>
    </formulas>
    <formulas>
        <name>LTVOutrosBancos</name>
        <dataType>Currency</dataType>
        <expression>{!$Record.ValorBem__c} - ({!$Record.ValorBem__c}*0.2)</expression>
        <scale>2</scale>
    </formulas>
    <formulas>
        <name>ValorEntrada</name>
        <dataType>Currency</dataType>
        <expression>IF(
    NOT(ISBLANK({!$Record.ValorFGTS__c})),
    ({!$Record.ValorBem__c} - {!$Record.ValorAprovado__c} - {!$Record.ValorFGTS__c}),
    ({!$Record.ValorBem__c} - {!$Record.ValorAprovado__c})
)</expression>
        <scale>2</scale>
    </formulas>
    <formulas>
        <name>ValorITBIRegistro</name>
        <dataType>Currency</dataType>
        <expression>{!$Record.ValorBem__c} * ({!$Record.PorcentagemITBIRegistro__c}/100)</expression>
        <scale>2</scale>
    </formulas>
