    <formulas>
        <name>FormulaItauITBI</name>
        <dataType>Currency</dataType>
        <expression>({!$Record.ValorAprovado__c} + ({!$Record.ValorBem__c} * ({!$Record.PorcentagemITBIRegistro__c}/100)))</expression>
        <scale>2</scale>
    </formulas>
    <formulas>
        <name>FormulaItauSemITBI</name>
