<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>ValidaMascaraCelular</fullName>
    <active>true</active>
    <errorConditionFormula>AND(
    CelularInternacional__c = false,
    NOT(ISBLANK(MobilePhone)),
    NOT(REGEX(MobilePhone, &apos;\\({1}[0-9]{2}\\){1} [0-9]{5}-[0-9]{4}&apos;))
)</errorConditionFormula>
    <errorDisplayField>MobilePhone</errorDisplayField>
    <errorMessage>Celular inválido. Digite apenas os números do DDD e Telefone no padrão (00) 00000-0000.</errorMessage>
</ValidationRule>
