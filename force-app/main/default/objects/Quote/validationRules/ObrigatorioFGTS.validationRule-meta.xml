<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>ObrigatorioFGTS</fullName>
    <active>true</active>
    <errorConditionFormula>AND(
    ISCHANGED(Status),
    ISPICKVAL(FGTS__c, &quot;&quot;),
    Opportunity.UnidadeNegocio__c = &apos;Produtos financeiros&apos;
)</errorConditionFormula>
    <errorMessage>Preencha o campo FGTS.</errorMessage>
</ValidationRule>
