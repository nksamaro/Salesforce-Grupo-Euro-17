<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>ImpedeRetornarStatusNovo</fullName>
    <active>true</active>
    <errorConditionFormula>AND(
  ISPICKVAL(Status, &quot;Novo&quot;),
  NOT(ISPICKVAL(PRIORVALUE(Status), &quot;Novo&quot;))
)</errorConditionFormula>
    <errorMessage>Não é possível retornar ao status &quot;Novo&quot;.</errorMessage>
</ValidationRule>
