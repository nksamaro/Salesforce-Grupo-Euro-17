<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>DescricaoFechamento</fullName>
    <active>true</active>
    <errorConditionFormula>AND( 
    ISPICKVAL( Status, &quot;Fechado&quot;),
     ISBLANK( DescricaoFechamento__c )
)</errorConditionFormula>
    <errorMessage>Para fechar um caso é obrigatório o preenchimento do campo “Descrição do fechamento”.</errorMessage>
</ValidationRule>
