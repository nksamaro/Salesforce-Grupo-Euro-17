<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Permissao_Beneficiario</fullName>
    <active>true</active>
    <errorConditionFormula>And ( Not(  ISBLANK( Oportunidade__c ) ) ,
      RecordType.Name = &apos;Debenturista&apos; 
    )</errorConditionFormula>
    <errorMessage>Para Oportunidades, nao é permitido criar registros Debenturistas</errorMessage>
</ValidationRule>
