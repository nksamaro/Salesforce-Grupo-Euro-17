<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>JustificativaPendenciaComprador</fullName>
    <active>true</active>
    <errorConditionFormula>AND(
   ISPICKVAL(PendenciaComprador__c, &apos;Sim&apos; ),
   ISBLANK( JustifiquePendenciaComprador__c)
)</errorConditionFormula>
    <errorDisplayField>JustifiquePendenciaComprador__c</errorDisplayField>
    <errorMessage>Informe a pendência do comprador.</errorMessage>
</ValidationRule>
