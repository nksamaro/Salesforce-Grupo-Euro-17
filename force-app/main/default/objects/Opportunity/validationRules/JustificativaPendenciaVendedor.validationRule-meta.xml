<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>JustificativaPendenciaVendedor</fullName>
    <active>true</active>
    <errorConditionFormula>AND(
   ISPICKVAL(PendenciaVendedor__c , &apos;Sim&apos; ),
   ISBLANK( JustifiquePendenciaVendedor__c)
)</errorConditionFormula>
    <errorDisplayField>JustifiquePendenciaVendedor__c</errorDisplayField>
    <errorMessage>Informe a pendência do vendedor.</errorMessage>
</ValidationRule>
