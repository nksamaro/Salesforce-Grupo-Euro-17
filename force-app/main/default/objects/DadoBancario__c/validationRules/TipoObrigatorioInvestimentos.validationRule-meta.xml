<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>TipoObrigatorioInvestimentos</fullName>
    <active>true</active>
    <errorConditionFormula>AND(
     Lead__r.UnidadeNegocio__c == &quot;Investimentos&quot;,
     ISPICKVAL(Tipo__c, &apos;&apos;)
)</errorConditionFormula>
    <errorMessage>Informe o tipo do dado bancário.</errorMessage>
</ValidationRule>
